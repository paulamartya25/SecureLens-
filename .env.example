# SecureLens Environment Configuration
# Copy this to .env and fill in your values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-this

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_WORKERS=4

# Model Configuration
MODEL_PATH=./cloud_server/models/best_model.pth
FEATURE_BACKBONE=resnet18
DEVICE=cpu

# Upload Configuration
UPLOAD_MAX_SIZE_MB=10
ALLOWED_EXTENSIONS=png,jpg,jpeg

# Encryption Configuration
CKKS_POLY_MODULUS_DEGREE=8192
CKKS_COEFF_MODULUS=60,40,40,60
CKKS_SCALE=1099511627776

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
API_KEY_REQUIRED=False
RATE_LIMIT_ENABLED=False

# Medical Data Configuration
MEDICAL_DATA_RETENTION_DAYS=30
ENCRYPT_PREDICTIONS=True
AUDIT_LOG_ENABLED=True

# Optional: Cloud Storage (for production)
CLOUD_STORAGE_TYPE=local
# CLOUD_STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_BUCKET_NAME=securelens-uploads
